{
  "name": "codex",
  "command": "codex",
  "additional_args": [
    "--json",
    "--model",
    "gpt-5.6-sol",
    "-c",
    "model_reasoning_effort=ultra",
    "--sandbox",
    "read-only",
    "--skip-git-repo-check"
  ],
  "env": {},
  "roles": {
    "default": {
      "prompt_path": "systemprompts/clink/default.txt",
      "role_args": []
    },
    "planner": {
      "prompt_path": "systemprompts/clink/default_planner.txt",
      "role_args": []
    },
    "codereviewer": {
      "prompt_path": "systemprompts/clink/codex_codereviewer.txt",
      "role_args": []
    }
  }
}
